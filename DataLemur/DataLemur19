SELECT CASE 
         WHEN (order_id % 2 != 0) AND (order_id = (SELECT MAX(order_id) FROM orders)) THEN order_id
         WHEN (order_id % 2 = 0) THEN order_id - 1
         WHEN (order_id % 2 != 0) THEN order_id + 1
         ELSE NULL
        END AS corrected_order_id,
        item
FROM orders
ORDER by corrected_order_id;
