WITH first_month_cte AS (SELECT issue_month,
       issue_year,
       card_name,
       issued_amount,
       ROW_NUMBER() 
        OVER(PARTITION BY card_name
             ORDER BY issue_year, issue_month) = 1 AS first_month
FROM monthly_cards_issued)

SELECT card_name, issued_amount
FROM first_month_cte
WHERE first_month = True
ORDER BY issued_amount DESC;
