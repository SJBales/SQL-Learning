-- Creating a CTE to get the filing years by user
WITH filing_years AS (SELECT user_id,
       EXTRACT(YEAR FROM filing_date) as filing_year,
       EXTRACT(YEAR FROM filing_date) - ROW_NUMBER()
         OVER(PARTITION BY user_id ORDER BY filing_date) AS island_id
FROM filed_taxes
WHERE product LIKE '%TurboTax%'),

-- Another CTE for the streaks
streaks AS (SELECT user_id,
       island_id,
       COUNT(*) AS streak
FROM filing_years
GROUP BY user_id, island_id)

-- Returning all users with at least a 3 month streak
SELECT DISTINCT user_id
FROM streaks
WHERE streak >= 3
ORDER BY user_id;
