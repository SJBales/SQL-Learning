/* Initial Investigation, calculating the trend and residual*/

-- Finding the total number of daily checkouts
WITH daily_checkouts AS (
  SELECT PARSE_DATE('%Y%m%d', event_date) AS event_date,
       EXTRACT(DAYOFWEEK FROM PARSE_DATE('%Y%m%d', event_date)) AS dow,
       SUM(CASE WHEN event_name = 'begin_checkout' THEN 1 ELSE 0 END) as checkouts
FROM `bigquery-public-data.ga4_obfuscated_sample_ecommerce.events_*`
GROUP BY event_date, dow),

-- Calculating the trend
trend AS (
  SELECT event_date,
         dow,
       AVG(checkouts) 
          OVER(ORDER BY event_date
               ROWS BETWEEN 3 PRECEDING AND 3 FOLLOWING) AS trend
FROM daily_checkouts),

-- Calculate seasonality
daily_seasonality AS (SELECT dow,
       AVG(checkouts) AS average_checkouts
FROM daily_checkouts
GROUP BY dow)

-- Put it all together
SELECT d.event_date,
       d.dow,
       d.checkouts,
       t.trend,
       s.average_checkouts,
       d.checkouts - t.trend - s.average_checkouts AS residual,
       t.trend + s.average_checkouts AS predicted
FROM daily_checkouts d
LEFT JOIN trend t ON d.event_date = t.event_date
LEFT JOIN daily_seasonality s ON d.dow = s.dow;

